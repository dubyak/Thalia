# ---- Backend (FastAPI) ----
# Required for chat/agent
OPENAI_API_KEY=your_openai_api_key

# Optional: Arize/OpenInference tracing (backend will start without these)
ARIZE_SPACE_ID=your_arize_space_id
ARIZE_API_KEY=your_arize_api_key
ARIZE_PROJECT_NAME=thalia-msme-agent

# ---- Frontend (Next.js) ----
# Backend URL used by /api/chat proxy. In Docker/Railway single container, backend is at 127.0.0.1:8000.
# Only set if backend runs elsewhere (e.g. separate service).
# BACKEND_URL=http://127.0.0.1:8000

# ---- Railway ----
# PORT is set by Railway at runtime; do not set manually.
